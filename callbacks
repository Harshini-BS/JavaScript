//passing  function as an argument to another function is called callback function

function handle(myname){
    setTimeout(()=>{
    console.log("Welcome"+myname)},3000);
}
    


function greet(name,callback){
    console.log("Hello"+name);
    callback(name);
}
greet("Harshini",handle);

