unction points(table){
    const totalpoints=table;

    const addpoints=(points)=>{
        return totalpoints+points;
    }
    
    const removepoints=(points)=>{
        return totalpoints-points;
    }
    
    const gettotalpoints=()=>{
        return totalpoints;
    }
    return{
       addpoints,removepoints,gettotalpoints};  
}
const table=points(100);
console.log(table.gettotalpoints());
console.log(table.addpoints(80));
console.log(table.removepoints(20));

output:

100
180
80
